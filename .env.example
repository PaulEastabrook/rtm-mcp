# RTM MCP Server Configuration
#
# Get your API key and shared secret from:
# https://www.rememberthemilk.com/services/api/keys.rtm
#
# After running `make setup`, the auth token will be added here

RTM_API_KEY=your_api_key_here
RTM_SHARED_SECRET=your_shared_secret_here
RTM_AUTH_TOKEN=  # Set by setup script

# --- Write gates (CONTRIBUTING.md § 6) -------------------------------------
# Deterministic server-side boundaries that refuse a malformed write, so the
# discipline is an invariant no agent, session, or scheduled engine can forget.
# Each enforces mechanical SHAPE only — canonical vocabulary stays plugin-side.

# Tag existence gate. ON by default; set to 0/false/no to allow new tags.
# RTM_STRICT_TAGS=1

# Note-title grammar gate: 'YYYY-MM-DD [HH:MM] — TYPE — summary'.
#   off   (default) inert
#   warn  log a malformed title but allow the write (observe before enforcing)
#   shape reject a malformed title
# Applies to add_note, and to edit_note only when it changes the title (a
# body-only edit of a legacy note is never blocked).
# RTM_STRICT_NOTES=off

# List-target writability gate: refuse add_task / move_task whose CALLER-NAMED
# destination list is smart (a saved-search view) or locked (Inbox, Sent).
# add_task's default-list fallback is not gated. Off by default.
# RTM_STRICT_LIST_TARGETS=0
